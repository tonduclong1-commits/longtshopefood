<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <title>Demo position</title>
    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body{
            padding-top: 60px;
        }

        header{
            width: 100%;
            border: 2px rgb(192, 192, 192) solid;
            display: flex;
            align-items: center;
            padding: 7px;
            position: fixed;
            top: 0px;
            background: white;
            
        }

        header img{
            width: 130px;
        }

        header i{
            font-size: 35px;
            position: absolute;
            right: 10px;
        }

        .container{
            width: 100%;
            height: 700px;
            border: 2px rgb(94, 39, 39) solid;
        }

        .icon-call{
            font-size: 70px;
            position: fixed;
            right: 15px;
            bottom: 15px;
        }

    </style>
</head>
<body>

    <header>
        <img src="https://upload.wikimedia.org/wikipedia/commons/2/20/FPT_Polytechnic.png" alt="">
        <i class='bx bx-menu' ></i>
    </header>

    <i class='bx bxs-phone-call bx-tada icon-call' ></i>

    <div class="container">
        content 1
    </div>
    <div class="container">
        content 2
    </div>

</body>
</html>
